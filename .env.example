NODE_ENV=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_PUBLIC_URL=http://localhost:8080
PORT=8080

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
FRONTEND_HTTPS=true
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://localhost:8080

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=fridgevoid
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGODB_URI=

# Uploads
UPLOAD_DIR=uploaded-images
MAX_UPLOAD_SIZE=5mb

# CORS
CORS_ALLOWED_ORIGINS=https://*,http://localhost:[*],https://localhost:[*],http://127.0.0.1:[*],https://127.0.0.1:[*],http://192.168.*.*:[*],https://192.168.*.*:[*],http://10.*.*.*:[*],https://10.*.*.*:[*],http://172.*.*.*:[*],https://172.*.*.*:[*],http://100.*.*.*:[*],https://100.*.*.*:[*],http://*.ts.net:[*],https://*.ts.net:[*]

# Leftover behavior
LEFTOVER_STATUS_EXPIRING_DAYS=1
LEFTOVER_STATUS_USE_SOON_DAYS=3
LEFTOVER_RECOVERY_DAYS=7
LEFTOVER_DEFAULT_LOCATION=Fridge

# Reserved for future auth support. Current frontend/backend do not enforce auth.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
